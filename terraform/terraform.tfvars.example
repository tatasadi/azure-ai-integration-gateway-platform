# Azure AI Integration Gateway - Terraform Variables
# Copy this file to terraform.tfvars and customize for your environment

# Core Configuration
project_name = "aigateway"
environment  = "dev"  # Options: dev, staging, prod
location     = "eastus"

# API Management Configuration
apim_publisher_name  = "AI Gateway Platform Team"
apim_publisher_email = "ai-gateway-admin@example.com"
apim_sku_name        = "Developer_1"  # Options: Developer_1, Standard_1, Premium_1

# AI Model Configuration
enable_gpt4o = true
enable_gpt35_turbo = false

# Resource Tags
tags = {
  Owner      = "platform-team"
  CostCenter = "engineering"
  Project    = "ai-gateway"
}
