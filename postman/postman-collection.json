                "key": "Ocp-Apim-Subscription-Key",
                "value": "{{subscriptionKey}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"The quarterly earnings report shows strong performance across all business units. Revenue increased by 15% year-over-year, reaching $50 million. Operating expenses were well controlled at $30 million. The cloud services division was the strongest performer with 30% growth. Customer acquisition increased by 25% with improved retention rates. The company expanded into three new markets in Asia. Research and development investment increased to support AI initiatives. The board approved a dividend of $0.50 per share.\",\n  \"style\": \"bullet_points\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/ai/summarize",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "summarize"]
            },
            "description": "Summarizes text in bullet-point format for easy scanning."
          },
          "response": []
        },
        {
          "name": "Extract Information - Invoice",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has extracted_data field\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('extracted_data');",
                  "    pm.expect(jsonData).to.have.property('tokens_used');",
                  "    pm.expect(jsonData).to.have.property('request_id');",
                  "    pm.expect(jsonData).to.have.property('model');",
                  "});",
                  "",
                  "pm.test(\"Extracted data has expected fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.extracted_data).to.have.property('invoice_number');",
                  "    pm.expect(jsonData.extracted_data).to.have.property('customer');",
                  "});",
                  "",
                  "console.log(\"Extracted Data:\", JSON.stringify(pm.response.json().extracted_data, null, 2));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Ocp-Apim-Subscription-Key",
                "value": "{{subscriptionKey}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"INVOICE #INV-2026-001\\nDate: March 17, 2026\\nBill To: Tech Solutions Inc.\\n123 Business Avenue\\nSan Francisco, CA 94105\\n\\nItem: Cloud Services Subscription\\nQuantity: 1\\nUnit Price: $1,500.00\\nTotal: $1,500.00\\n\\nDue Date: April 16, 2026\\nPayment Terms: Net 30\\n\\nThank you for your business!\",\n  \"schema\": {\n    \"type\": \"object\",\n    \"properties\": {\n      \"invoice_number\": {\n        \"type\": \"string\"\n      },\n      \"invoice_date\": {\n        \"type\": \"string\",\n        \"format\": \"date\"\n      },\n      \"customer\": {\n        \"type\": \"string\"\n      },\n      \"total\": {\n        \"type\": \"number\"\n      },\n      \"due_date\": {\n        \"type\": \"string\",\n        \"format\": \"date\"\n      }\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/ai/extract",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "extract"]
            },
            "description": "Extracts structured information from an invoice using a defined JSON schema.\n\n**Parameters:**\n- `text` (required): Text to extract information from (10-400,000 characters)\n- `schema` (required): JSON Schema defining the expected structure of extracted data"
          },
          "response": [
            {
              "name": "Successful Extraction",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Ocp-Apim-Subscription-Key",
                    "value": "{{subscriptionKey}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"text\": \"INVOICE #12345\\nDate: March 11, 2026\\nBill To: Acme Corp\\nTotal Amount: $2,450.00\",\n  \"schema\": {\n    \"type\": \"object\",\n    \"properties\": {\n      \"invoice_number\": {\"type\": \"string\"},\n      \"invoice_date\": {\"type\": \"string\", \"format\": \"date\"},\n      \"customer\": {\"type\": \"string\"},\n      \"total\": {\"type\": \"number\"}\n    }\n  }\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/ai/extract",
                  "host": ["{{baseUrl}}"],
                  "path": ["ai", "extract"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                },
                {
                  "key": "X-Request-Id",
                  "value": "b2c3d4e5-f6a7-4890-1234-567890bcdefg"
                },
                {
                  "key": "X-Token-Usage",
                  "value": "234"
                }
              ],
              "body": "{\n  \"extracted_data\": {\n    \"invoice_number\": \"12345\",\n    \"invoice_date\": \"2026-03-11\",\n    \"customer\": \"Acme Corp\",\n    \"total\": 2450.00\n  },\n  \"confidence\": 0.98,\n  \"tokens_used\": 234,\n  \"request_id\": \"b2c3d4e5-f6a7-4890-1234-567890bcdefg\",\n  \"model\": \"gpt-4o\"\n}"
            }
          ]
        },
