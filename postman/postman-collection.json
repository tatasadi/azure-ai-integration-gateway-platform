  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Set timestamp for requests",
          "pm.environment.set(\"timestamp\", new Date().toISOString());",
          "",
          "// Log request details",
          "console.log(\"Request URL:\", pm.request.url.toString());",
          "console.log(\"Request Time:\", pm.environment.get(\"timestamp\"));"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Log response time",
          "console.log(\"Response Time:\", pm.response.responseTime, \"ms\");",
          "",
          "// Check rate limit headers if present",
          "if (pm.response.headers.has(\"X-RateLimit-Remaining\")) {",
          "    var remaining = pm.response.headers.get(\"X-RateLimit-Remaining\");",
          "    console.log(\"Rate Limit Remaining:\", remaining);",
          "    ",
          "    if (parseInt(remaining) < 10) {",
          "        console.warn(\"WARNING: Rate limit almost exceeded! Remaining:\", remaining);",
          "    }",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://apim-aigateway-dev-eastus-01.azure-api.net",
      "type": "string"
    },
    {
      "key": "subscriptionKey",
      "value": "YOUR_SUBSCRIPTION_KEY_HERE",
      "type": "string"
