{
  "info": {
    "name": "Azure AI Integration Gateway API",
    "_postman_id": "azure-ai-gateway-collection",
    "description": "Enterprise-grade AI Gateway providing centralized governance, security, rate limiting, and observability for AI services.\n\n## Features\n- Text Summarization: Condense long text into concise summaries\n- Information Extraction: Extract structured data from unstructured text\n- Health Monitoring: Check API and backend service health\n\n## Authentication\nAll requests require a subscription key in the `Ocp-Apim-Subscription-Key` header.\n\n## Rate Limits\n- Rate Limit: 100 requests per minute per subscription\n- Daily Quota: 10,000 requests per day per subscription\n\n## Setup Instructions\n1. Set the `baseUrl` variable to your APIM gateway URL\n2. Set the `subscriptionKey` variable to your subscription key\n3. Select the appropriate environment (dev, staging, or prod)\n\nFor more information, visit: https://docs.ai-gateway.example.com",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "AI Operations",
      "item": [
        {
          "name": "Summarize Text - Basic",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has summary field\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('summary');",
                  "    pm.expect(jsonData).to.have.property('tokens_used');",
                  "    pm.expect(jsonData).to.have.property('request_id');",
                  "    pm.expect(jsonData).to.have.property('model');",
                  "});",
                  "",
                  "pm.test(\"Response headers include tracking info\", function () {",
                  "    pm.response.to.have.header('X-Request-Id');",
                  "    pm.response.to.have.header('X-Token-Usage');",
                  "});",
                  "",
                  "// Store request_id for tracking",
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"last_request_id\", jsonData.request_id);",
                  "",
                  "console.log(\"Summary:\", jsonData.summary);",
                  "console.log(\"Tokens used:\", jsonData.tokens_used);",
                  "console.log(\"Request ID:\", jsonData.request_id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Ocp-Apim-Subscription-Key",
                "value": "{{subscriptionKey}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"The global economy showed signs of recovery in 2026 as technology sectors led growth across major markets. Artificial intelligence continued to drive innovation in healthcare, finance, and manufacturing. Companies invested heavily in AI infrastructure, while governments developed regulatory frameworks to ensure responsible deployment. Experts predict sustained growth as AI adoption accelerates across industries.\",\n  \"style\": \"concise\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/ai/summarize",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "summarize"]
            },
            "description": "Summarizes long text into a concise summary using GPT-4o.\n\n**Parameters:**\n- `text` (required): Text to summarize (10-400,000 characters)\n- `style` (optional): Summary style - 'concise', 'detailed', or 'bullet_points' (default: 'concise')\n- `max_length` (optional): Maximum length in tokens (50-5000, default: 500)"
          },
          "response": [
            {
              "name": "Successful Summarization",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Ocp-Apim-Subscription-Key",
                    "value": "{{subscriptionKey}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"text\": \"The global economy showed signs of recovery in 2026 as technology sectors led growth across major markets. Artificial intelligence continued to drive innovation in healthcare, finance, and manufacturing.\",\n  \"style\": \"concise\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/ai/summarize",
                  "host": ["{{baseUrl}}"],
                  "path": ["ai", "summarize"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                },
                {
                  "key": "X-Request-Id",
                  "value": "a1b2c3d4-e5f6-4789-0123-456789abcdef"
                },
                {
                  "key": "X-Token-Usage",
                  "value": "156"
                },
                {
                  "key": "X-RateLimit-Remaining",
                  "value": "99"
                }
              ],
              "body": "{\n  \"summary\": \"Global economy recovers in 2026, driven by AI innovation in key sectors.\",\n  \"tokens_used\": 156,\n  \"request_id\": \"a1b2c3d4-e5f6-4789-0123-456789abcdef\",\n  \"model\": \"gpt-4o\"\n}"
            }
          ]
        },
        {
          "name": "Summarize Text - Detailed",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has all required fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('summary');",
                  "    pm.expect(jsonData).to.have.property('tokens_used');",
                  "    pm.expect(jsonData).to.have.property('request_id');",
                  "    pm.expect(jsonData).to.have.property('model');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Ocp-Apim-Subscription-Key",
                "value": "{{subscriptionKey}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Artificial intelligence continues to transform industries worldwide. Recent breakthroughs in large language models have enabled more sophisticated applications in healthcare, finance, and education. Companies are investing heavily in AI infrastructure and talent acquisition. Healthcare providers use AI for diagnostic assistance and personalized treatment plans. Financial institutions leverage AI for fraud detection and risk assessment. Educational platforms implement AI tutors for personalized learning experiences. Regulatory frameworks are being developed to ensure responsible AI deployment. Privacy concerns and ethical considerations remain at the forefront of policy discussions. Experts predict continued growth in AI adoption across all sectors over the next decade.\",\n  \"max_length\": 1000,\n  \"style\": \"detailed\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/ai/summarize",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "summarize"]
            },
            "description": "Summarizes text with a detailed style and custom maximum length."
          },
          "response": []
        },
        {
          "name": "Summarize Text - Bullet Points",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
